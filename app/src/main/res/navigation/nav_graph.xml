<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.hfad.digital_assistant.view.SplashFragment"
        android:label="fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_registrationFragment"
            app:destination="@id/registrationFragment"/>
        <action
            android:id="@+id/action_splashFragment_to_mainFragment"
            app:destination="@id/mainFragment"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.hfad.digital_assistant.view.LoginFragment"
        android:label="fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.hfad.digital_assistant.view.MainFragment"
        android:label="fragment_main"/>

    <fragment
        android:id="@+id/registrationFragment"
        android:name="com.hfad.digital_assistant.view.RegistrationFragment"
        android:label="fragment_registration"
        tools:layout="@layout/fragment_registration">

        <!--Для анимации-->
        <action
            android:id="@+id/action_registrationFragment_to_mainFragment"
            app:destination="@id/mainFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim">
        </action>
    </fragment>

    <action
        android:id="@+id/action_registrationFragment_to_loginFragment"
        app:destination="@id/loginFragment" />

    <fragment
        android:id="@+id/routeFragment"
        android:name="com.hfad.digital_assistant.RouteFragment"
        android:label="Route"
        tools:layout="@layout/fragment_route" />

    <fragment
        android:id="@+id/practicumFragment"
        android:name="com.hfad.digital_assistant.PracticumFragment"
        android:label="Practicum"
        tools:layout="@layout/fragment_practicum" />

    <fragment
        android:id="@+id/monitoringFragment"
        android:name="com.hfad.digital_assistant.MonitoringFragment"
        android:label="Monitoring"
        tools:layout="@layout/fragment_monitoring" />

    <fragment
        android:id="@+id/reflectionFragment"
        android:name="com.hfad.digital_assistant.ReflectionFragment"
        android:label="Reflection"
        tools:layout="@layout/fragment_reflection" />



</navigation>