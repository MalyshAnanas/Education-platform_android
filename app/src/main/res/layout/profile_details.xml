<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    android:layout_marginBottom="-32dp"
    app:cardBackgroundColor="@color/blue_for_blocks">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Ручка -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/white"
            android:alpha="0.4"
            android:layout_marginBottom="24dp"/>

        <!-- Фото -->
        <androidx.cardview.widget.CardView
            android:id="@+id/userPhotoContainerProfile"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            app:cardCornerRadius="48dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/User_photo_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/userPhoto" />
        </androidx.cardview.widget.CardView>

        <!-- Имя (отображение) -->
        <TextView
            android:id="@+id/userNameTextProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:maxLines="2"
            android:text="Иванов Иван Иванович"
            android:textColor="@color/white"
            android:textSize="22sp" />

        <!-- Поменять фото -->
        <TextView
            android:id="@+id/ChangePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center"
            android:fontFamily="sans-serif"
            android:text="Поменять фото"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:alpha="0.7"/>

        <!-- ===== РЕДАКТИРОВАНИЕ ===== -->

        <!-- ФИО -->
        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="ФИО"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:backgroundTint="@color/white"/>

        <!-- Должность -->
        <EditText
            android:id="@+id/etPosition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Должность"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:backgroundTint="@color/white"/>

        <!-- Организация -->
        <EditText
            android:id="@+id/etOrganization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Организация"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:backgroundTint="@color/white"/>

        <!-- Кнопка сохранить -->
        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Сохранить"
            android:textAllCaps="false"
            android:backgroundTint="@color/white"
            android:textColor="@color/blue_for_blocks"/>

        <!-- Выход -->
        <TextView
            android:id="@+id/Exit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:text="Выйти из аккаунта"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:alpha="0.8"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>