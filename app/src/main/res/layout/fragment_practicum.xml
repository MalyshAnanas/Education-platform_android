<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".view.PracticumFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <View
                android:id="@+id/blueTopRectPrac"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/rounded_bottom_shape"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/practicumHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Практикум"
                android:textSize="36sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/completedCasesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выполнено: 0 кейса\nНе выполнено: 0 кейса"
                android:textSize="20sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/white"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="24dp"
                app:layout_constraintTop_toBottomOf="@id/practicumHeader"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/userNamePrac"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Малыш А.В."
                android:textSize="25sp"
                android:textColor="@color/black"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintTop_toTopOf="@id/userPhotoContainerPrac"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/userPhotoContainerPrac"
                app:layout_constraintBottom_toBottomOf="@id/userPhotoContainerPrac" />

            <androidx.cardview.widget.CardView
                android:id="@+id/userPhotoContainerPrac"
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="40dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="32dp"
                android:clickable="true"
                app:layout_constraintTop_toBottomOf="@id/blueTopRectPrac"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView
                    android:id="@+id/userImagePrac"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/userPhoto"
                    android:scaleType="centerCrop"/>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/casesRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/userPhotoContainerPrac"/>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
