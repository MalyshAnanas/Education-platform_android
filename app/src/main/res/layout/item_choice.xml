<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="20dp"
    app:cardCornerRadius="43dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_box_for_mark"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <!-- TEXT -->
        <TextView
            android:id="@+id/questionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/blue_for_text"
            android:fontFamily="sans-serif-black"
            android:textAlignment="center"/>

        <!-- EMOJIS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">

            <ImageView
                android:id="@+id/excellent"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="4dp"
                android:src="@drawable/exelmark"/>

            <ImageView
                android:id="@+id/good"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="4dp"
                android:src="@drawable/goodmark"/>

            <ImageView
                android:id="@+id/normal"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="4dp"
                android:src="@drawable/normmark"/>

            <ImageView
                android:id="@+id/bad"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="4dp"
                android:src="@drawable/badmark"/>

            <ImageView
                android:id="@+id/terrible"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_margin="4dp"
                android:src="@drawable/terrmark"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>